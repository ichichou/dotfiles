# Auto IME On/Off {{{

# IME の切り替えには macism を使う
# osascript 経由で AppleScript/JavaScript を使うと macism より遅くなる

var ime_cmd  = 'macism'
var en_ime   = 'net.mtgto.inputmethod.macSKK.ascii'
var ja_ime   = 'net.mtgto.inputmethod.macSKK.hiragana'
var prev_ime = en_ime

# -- Auto IME Off
augroup vimrc
  autocmd VimEnter,VimResume,FocusGained * ime_off()
  autocmd InsertLeave * ime_off()
augroup END

# -- Auto IME On/Off
# Insert mode を抜けた後、macism の実行を待つ間、
# 少しの時間キー入力を受け付けなくなる問題がある
# これは system() の代わりに job_start() を使っても同じである
#
# augroup vimrc
#   autocmd VimEnter,VimResume,FocusGained * ime_off()
#   autocmd InsertLeave * save_ime_and_ime_off()
#   autocmd InsertEnter * restore_ime()
# augroup END

def ime_off(): void
  job_start([ime_cmd, en_ime], {'stoponexit': ''})
enddef

def ime_on(): void
  job_start([ime_cmd, ja_ime], {'stoponexit': ''})
enddef

def restore_ime(): void
  if prev_ime == ja_ime
    ime_on()
  endif
enddef

def save_ime_and_ime_off(): void
  prev_ime = trim(system(ime_cmd))
  ime_off()
enddef

