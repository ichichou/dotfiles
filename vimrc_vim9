# Set Status Line (global) {{{

var mode_map = {
  'n':      '  NORMAL ',
  'i':      '  INSERT ',
  'R':      ' REPLACE ',
  'v':      '  VISUAL ',
  'V':      '  V-LINE ',
  "\<C-v>": ' V-BLOCK ',
  'c':      ' COMMAND ',
  's':      '  SELECT ',
  'S':      '  S-LINE ',
  "\<C-s>": ' S-BLOCK ',
  't':      ' TERMINAL '
}

def g:GetMode(): string
  return get(mode_map, mode(), '')
enddef

def g:SetStatusLine(): string
  var fenc = &fileencoding != '' ? &fileencoding : &encoding
  var ft   = &filetype     != '' ? &filetype     : 'no ft'

  var percentage: string
  var lines: string
  var cols: string

  # Percent
  var pct_num = line('.') * 100 / line('$')
  if pct_num < 10
    percentage = '     ' .. pct_num .. '%%'
  elseif pct_num < 100
    percentage = '    ' .. pct_num .. '%%'
  else
    percentage = '   ' .. pct_num .. '%%'
  endif

  # Lines
  if line('.') < 10
    lines = '    %l:'
  elseif line('.') < 100
    lines = '   %l:'
  else
    lines = '  %l:'
  endif

  # Columns
  if col('.') < 10
    cols = '%c   '
  elseif col('.') < 100
    cols = '%c  '
  else
    cols = '%c '
  endif

  return g:GetMode()
    .. '| %t %m'
    .. '%='
    .. '%{&fileformat}' .. ' | ' .. fenc .. ' | ' .. ft
    .. percentage .. lines .. cols
enddef

