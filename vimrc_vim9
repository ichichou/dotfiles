# Insert Blank Lines {{{

nnoremap <expr> go <SID>blank_below()
nnoremap <expr> gO <SID>blank_above()

def blank_below(type = ''): string
  if type == ''
    &operatorfunc = blank_below
    return 'g@ '
  else
    return ''
  endif

  for i in range(v:count1)
    append('.', '')
  endfor
enddef

def blank_above(type = ''): string
  if type == ''
    &operatorfunc = blank_above
    return 'g@ '
  else
    return ''
  endif

  for i in range(v:count1)
    append(line('.') - 1, '')
  endfor
enddef

