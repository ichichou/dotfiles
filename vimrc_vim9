# Timestamp {{{

augroup vimrc
  autocmd FileType markdown
        \ nnoremap <buffer> <Leader>d <Cmd><SID>timestamp_below()<CR>
  autocmd FileType markdown
        \ nnoremap <buffer> <Leader>D <Cmd><SID>timestamp_above()<CR>
augroup END

def set_timestamp(): string
  var timestamp = '## ' .. strftime('%Y-%m-%d %H:%M:%S')
  return timestamp
enddef

def timestamp_below(): void
  var timestamp = set_timestamp()

  if strlen(getline('.')) > 0
    append('.', ['', timestamp, ''])
    cursor(line('.') + 3, 1)
  elseif strlen(getline(line('.') - 1)) > 0
    append('.', [timestamp, ''])
    cursor(line('.') + 2, 1)
  else
    append(line('.') - 1, timestamp)
  endif
  startinsert
enddef

def timestamp_above(): void
  var timestamp = set_timestamp()

  if strlen(getline('.')) > 0
    append(line('.') - 1, timestamp)
  else
    setline('.', timestamp)
  endif
enddef

