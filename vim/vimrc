# Insert Blank Lines {{{

nnoremap <expr> go <SID>BlankBelow()
nnoremap <expr> gO <SID>BlankAbove()

def BlankBelow(type = ''): string
  if type == ''
    &operatorfunc = BlankBelow
    return 'g@ '
  endif

  for i in range(v:count1)
    append('.', '')
  endfor
  return ''
enddef

def BlankAbove(type = ''): string
  if type == ''
    &operatorfunc = BlankAbove
    return 'g@ '
  endif

  for i in range(v:count1)
    append(line('.') - 1, '')
  endfor
  return ''
enddef

