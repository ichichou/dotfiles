# Auto IME On/Off {{{

# IME の切り替えには macism を使う
# osascript 経由で AppleScript/JavaScript を使うと macism より遅くなる

var ime_cmd  = 'macism'
var en_ime   = 'net.mtgto.inputmethod.macSKK.ascii'
var ja_ime   = 'net.mtgto.inputmethod.macSKK.hiragana'
var prev_ime = en_ime

# -- Auto IME Off
augroup vimrc
  autocmd VimEnter,VimResume,FocusGained * ImeOff()
  autocmd InsertLeave * ImeOff()
augroup END

# -- Auto IME On/Off
# Insert mode を抜けた後、macism の実行を待つ間、
# 少しの時間キー入力を受け付けなくなる問題がある
# これは system() の代わりに job_start() を使っても同じである
#
# augroup vimrc
#   autocmd VimEnter,VimResume,FocusGained * ImeOff()
#   autocmd InsertLeave * SaveImeAndImeOff()
#   autocmd InsertEnter * RestoreIme()
# augroup END

def ImeOff(): void
  job_start([ime_cmd, en_ime], {'stoponexit': ''})
enddef

def ImeOn(): void
  job_start([ime_cmd, ja_ime], {'stoponexit': ''})
enddef

def RestoreIme(): void
  if prev_ime == ja_ime
    ImeOn()
  endif
enddef

def SaveImeAndImeOff(): void
  prev_ime = trim(system(ime_cmd))
  ImeOff()
enddef

