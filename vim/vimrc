def OpenJournalFile(): void
  var file_name = strftime('%Y-%m-%d') .. '.md'
  var file_path_pattern = 'zk/journal/' .. file_name
  var win_id = bufwinid(file_path_pattern)

  if win_id > 0
    win_gotoid(win_id)
  else
    execute 'edit' journal_dir .. '/' .. file_name
  endif
enddef

def OpenJournalDir(): void
  execute 'edit' journal_dir
enddef

