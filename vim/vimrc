# Fill Line {{{

command! FillLine FillLine()

def FillLine(): void
  var width = 50
  var str = substitute(getline('.'), ' \+$', '', '')
  var display_width = strdisplaywidth(str)
  var sep_len = width - display_width - 1
  if sep_len < 1
    sep_len = 1
  endif
  var sep = repeat('-', sep_len)
  setline('.', str .. ' ' .. sep)
enddef

