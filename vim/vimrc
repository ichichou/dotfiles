# Timestamp {{{

augroup vimrc
  autocmd FileType markdown
        \ nnoremap <buffer> <Leader>d <ScriptCmd>TimestampBelow()<CR>
  autocmd FileType markdown
        \ nnoremap <buffer> <Leader>D <ScriptCmd>TimestampAbove()<CR>
augroup END

def SetTimestamp(): string
  var timestamp = '## ' .. strftime('%Y-%m-%d %H:%M:%S')
  return timestamp
enddef

def TimestampBelow(): void
  var timestamp = SetTimestamp()

  if strlen(getline('.')) > 0
    append('.', ['', timestamp, ''])
    cursor(line('.') + 3, 1)
  elseif strlen(getline(line('.') - 1)) > 0
    append('.', [timestamp, ''])
    cursor(line('.') + 2, 1)
  else
    append(line('.') - 1, timestamp)
  endif
  startinsert
enddef

def TimestampAbove(): void
  var timestamp = SetTimestamp()

  if strlen(getline('.')) > 0
    append(line('.') - 1, timestamp)
  else
    setline('.', timestamp)
  endif
enddef

